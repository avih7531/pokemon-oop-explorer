' Shared PlantUML skinparams using the Pokemon OOP Explorer palette.
' Keep this file self-contained and include it from sibling diagrams
' via !include ../_theme.iuml (or adjust the relative path).

skinparam backgroundColor #242933
skinparam defaultFontColor #E5E9F0
skinparam defaultFontName "DejaVu Sans Mono"
skinparam defaultFontSize 13
skinparam roundCorner 8
skinparam shadowing false

skinparam actorStyle awesome
skinparam actor {
    BackgroundColor #434C5E
    BorderColor #a97ea1
    FontColor #E5E9F0
    FontSize 13
}

skinparam usecase {
    BackgroundColor #5E81AC
    BorderColor #88C0D0
    FontColor #ffffff
    FontSize 12
}

skinparam package {
    BackgroundColor #2B3242
    BorderColor #4C566A
    FontColor #88C0D0
    FontSize 13
}

skinparam arrow {
    Color #88C0D0
    FontColor #e7c173
    Thickness 1.2
}

skinparam note {
    BackgroundColor #434C5E
    BorderColor #4C566A
    FontColor #E5E9F0
}

skinparam title {
    FontColor #e279a1
    FontSize 18
}

skinparam activity {
    BackgroundColor #5E81AC
    BorderColor #88C0D0
    FontColor #ffffff
    StartColor #97b67c
    EndColor #b74e58
    BarColor #a97ea1
    DiamondBackgroundColor #434C5E
    DiamondBorderColor #e7c173
    DiamondFontColor #E5E9F0
    ArrowColor #88C0D0
    ArrowFontColor #e7c173
}

skinparam partition {
    BackgroundColor #2B3242
    BorderColor #4C566A
    FontColor #88C0D0
}

skinparam sequence {
    ActorBackgroundColor #434C5E
    ActorBorderColor #a97ea1
    ActorFontColor #E5E9F0
    ParticipantBackgroundColor #5E81AC
    ParticipantBorderColor #88C0D0
    ParticipantFontColor #ffffff
    LifeLineBackgroundColor #4C566A
    LifeLineBorderColor #4C566A
    ArrowColor #88C0D0
    GroupBackgroundColor #2B3242
    GroupBorderColor #4C566A
    GroupFontColor #e279a1
}
