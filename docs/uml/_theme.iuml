skinparam backgroundColor #242933
skinparam defaultFontColor #E5E9F0
skinparam defaultFontName "DejaVu Sans Mono"
skinparam defaultFontSize 13
skinparam roundCorner 8
skinparam shadowing false
skinparam dpi 160

skinparam title {
    FontColor #e279a1
    FontSize 18
}

skinparam legend {
    BackgroundColor #434C5E
    BorderColor #a97ea1
    FontColor #E5E9F0
}

skinparam note {
    BackgroundColor #434C5E
    BorderColor #a97ea1
    FontColor #E5E9F0
}

skinparam arrow {
    Color #88C0D0
    FontColor #E5E9F0
    Thickness 1.2
}

skinparam package {
    BackgroundColor #434C5E
    BorderColor #a97ea1
    FontColor #88C0D0
    FontSize 13
}

skinparam actorStyle awesome
skinparam actor {
    BackgroundColor #434C5E
    BorderColor #a97ea1
    FontColor #E5E9F0
    FontSize 13
}

skinparam usecase {
    BackgroundColor #5E81AC
    BorderColor #a97ea1
    FontColor #ffffff
    FontSize 12
}

skinparam class {
    BackgroundColor #434C5E
    BorderColor #a97ea1
    FontColor #E5E9F0
    HeaderBackgroundColor #5E81AC
    HeaderFontColor #ffffff
    AttributeFontColor #E5E9F0
    StereotypeFontColor #88C0D0
}

skinparam object {
    BackgroundColor #434C5E
    BorderColor #a97ea1
    FontColor #E5E9F0
}

skinparam activity {
    BackgroundColor #5E81AC
    BorderColor #a97ea1
    FontColor #ffffff
    StartColor #88C0D0
    EndColor #e279a1
    BarColor #a97ea1
    DiamondBackgroundColor #434C5E
    DiamondBorderColor #a97ea1
    DiamondFontColor #E5E9F0
    ArrowColor #88C0D0
    ArrowFontColor #E5E9F0
}

skinparam partition {
    BackgroundColor #434C5E
    BorderColor #a97ea1
    FontColor #88C0D0
}

skinparam sequence {
    ActorBackgroundColor #434C5E
    ActorBorderColor #a97ea1
    ActorFontColor #E5E9F0
    ParticipantBackgroundColor #5E81AC
    ParticipantBorderColor #a97ea1
    ParticipantFontColor #ffffff
    LifeLineBackgroundColor #4C566A
    LifeLineBorderColor #4C566A
    ArrowColor #88C0D0
    MessageAlign center
    GroupBackgroundColor #434C5E
    GroupBorderColor #a97ea1
    GroupFontColor #e279a1
    DividerBackgroundColor #4C566A
    DividerBorderColor #a97ea1
    DividerFontColor #88C0D0
}
